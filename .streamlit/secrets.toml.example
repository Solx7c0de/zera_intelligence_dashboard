# ──────────────────────────────────────────────────────────────
# Streamlit secrets template for ZERA Analytics
# ──────────────────────────────────────────────────────────────
# To use AI Query Chat with Gemini-powered NL→SQL:
#
#   1. Copy this file to .streamlit/secrets.toml
#   2. Replace the placeholder below with your actual Gemini API key
#      (get one free at https://aistudio.google.com/apikey)
#   3. NEVER commit the real secrets.toml to git
#      (.streamlit/secrets.toml is already in .gitignore)
#
# On Streamlit Cloud: set this in
#   App settings → Secrets → paste the line below with your real key.
# ──────────────────────────────────────────────────────────────

GEMINI_API_KEY = "your-gemini-api-key-here"
